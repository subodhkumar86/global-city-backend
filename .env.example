# Copy this to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/global-city-insights?retryWrites=true&w=majority

# OpenWeatherMap API key (free tier at openweathermap.org)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ExchangeRate-API key (free tier at exchangerate-api.com) - optional, falls back to open.er-api.com
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# Server port
PORT=5000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
